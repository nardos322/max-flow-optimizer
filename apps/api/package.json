{
  "name": "@maxflow/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && node dist/server.js",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "test": "pnpm --filter @maxflow/contracts build && pnpm --filter @maxflow/domain build && pnpm --dir ../.. run build:engine && vitest run",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@maxflow/contracts": "workspace:*",
    "@maxflow/domain": "workspace:*",
    "express": "4.18.2",
    "pino": "8.17.2"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.12.2",
    "@types/supertest": "2.0.16",
    "supertest": "6.3.4",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
