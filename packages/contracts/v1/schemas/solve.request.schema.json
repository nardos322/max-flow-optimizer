{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://max-flow-optimizer.local/contracts/v1/solve.request.schema.json",
  "title": "SolveRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "instanceId",
    "maxDaysPerMedic",
    "periods",
    "days",
    "medics",
    "availability"
  ],
  "properties": {
    "instanceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "maxDaysPerMedic": {
      "type": "integer",
      "minimum": 0
    },
    "periods": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "dayIds"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "dayIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            }
          }
        }
      }
    },
    "days": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "date"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "date": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "medics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        }
      }
    },
    "availability": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "medicId",
          "dayId"
        ],
        "properties": {
          "medicId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "dayId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        }
      }
    }
  }
}
