{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://max-flow-optimizer.local/contracts/v1/error.schema.json",
  "title": "ApiErrorV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "error"
  ],
  "properties": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestId",
        "timestamp",
        "code",
        "message"
      ],
      "properties": {
        "requestId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "code": {
          "type": "string",
          "enum": [
            "INVALID_INPUT",
            "DUPLICATE_ID",
            "DUPLICATE_DAY_DATE",
            "UNKNOWN_REFERENCE",
            "DAY_WITHOUT_PERIOD",
            "DAY_IN_MULTIPLE_PERIODS",
            "INVALID_CAPACITY",
            "ENGINE_EXECUTION_FAILED",
            "ENGINE_TIMEOUT",
            "ENGINE_INVALID_OUTPUT",
            "ENGINE_INTERNAL_ERROR",
            "INTERNAL_ERROR"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "details": {
          "type": "object"
        }
      }
    }
  }
}
